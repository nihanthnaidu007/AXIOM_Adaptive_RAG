# AXIOM — Adaptive Intelligence Platform
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# --- Required ---

# Anthropic API Key (powers Claude for answer generation)
ANTHROPIC_API_KEY=your_anthropic_key_here

# OpenAI API Key (powers text-embedding-3-small for vector retrieval)
OPENAI_API_KEY=your_openai_key_here

# --- Evaluation ---

# Set to false only if you are running Ollama locally and want to use it for evaluation.
# Default is true. In all cloud deployments, keep this true.
USE_CLAUDE_EVALUATOR=true

# If USE_CLAUDE_EVALUATOR=false, configure local Ollama:
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_CRITIC_MODEL=llama3.2

# --- Web Search (Tavily) ---

# Get your API key at https://tavily.com
# Leave empty to disable web search fallback entirely.
# When set, AXIOM uses Tavily when the document corpus has no relevant chunks.
TAVILY_API_KEY=

# Search depth (basic or advanced). The node overrides this automatically:
# advanced when the corpus is empty, basic otherwise.
# You do not need to change this manually.
TAVILY_SEARCH_DEPTH=basic

# Maximum Tavily results per search call.
TAVILY_MAX_RESULTS=5

# --- Infrastructure (defaults match docker-compose.yml) ---

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_this_before_deployment

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=axiom
POSTGRES_PASSWORD=change_this_before_deployment
POSTGRES_DB=axiom_rag
POSTGRES_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# --- API security ---

API_KEY=                              # Set a strong random string to enable auth
CORS_ORIGINS=http://localhost:3000    # comma-separated list for production

# --- LangSmith Observability (optional but recommended) ---
# Sign up free at https://smith.langchain.com
# Then uncomment these three lines:
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your_langsmith_key_here
# LANGCHAIN_PROJECT=axiom-rag

